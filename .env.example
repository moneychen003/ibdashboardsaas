# IB Dashboard SaaS Environment Configuration

# ------------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ib_dashboard
DB_USER=postgres
DB_PASSWORD=postgres

# ------------------------------------------------------------------
# Redis (for RQ job queue)
# ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------
# Flask / JWT
# ------------------------------------------------------------------
FLASK_SECRET_KEY=change_this_to_a_random_string_at_least_32_chars
JWT_SECRET_KEY=change_this_to_another_random_string_for_jwt
CORS_ORIGIN=http://localhost:5173

# ------------------------------------------------------------------
# File Storage
# ------------------------------------------------------------------
UPLOAD_DIR=uploads
BACKUP_DIR=backups
MAX_UPLOAD_MB=50

# ------------------------------------------------------------------
# SaaS Settings
# ------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
DEFAULT_TIER=free

# ------------------------------------------------------------------
# AI (used by portfolios_ai.py: ai_suggest / ai_match_to_existing)
# DashScope (阿里百炼) Anthropic-compatible endpoint
# ------------------------------------------------------------------
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxx
AI_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic/v1
AI_MODEL=qwen3.6-plus
# Fallback if qwen3.6-plus unavailable: qwen3-coder-next / qwen3-coder-plus
